# ===== BACKEND ENVIRONMENT VARIABLES =====
NODE_ENV=production
PORT=5000

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/balaji_construction?retryWrites=true&w=majority
MONGO_USERNAME=root
MONGO_PASSWORD=your_mongo_password

# Cors Configuration
CORS_ORIGIN=https://yourdomain.com

# Email Configuration (Nodemailer)
SMTP_SERVICE=gmail
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@balajiconstruction.com

# Application URLs
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://api.yourdomain.com

# ===== FRONTEND ENVIRONMENT VARIABLES =====
REACT_APP_API_URL=https://api.yourdomain.com
REACT_APP_ENV=production

# ===== VERCEL DEPLOYMENT =====
VERCEL_ORG_ID=your_vercel_org_id
VERCEL_TOKEN=your_vercel_token
GITHUB_REPO_FRONTEND=anil4749/BalajiConstrucation

# ===== RENDER DEPLOYMENT =====
RENDER_API_KEY=your_render_api_key
RENDER_BACKEND_SERVICE_ID=your_render_service_id

# ===== GITLAB CI/CD =====
GITLAB_CI_TOKEN=your_gitlab_ci_token
