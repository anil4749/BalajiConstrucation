# Backend Environment Variables
# Copy this file to .env and fill in your values

# ========================
# SERVER CONFIGURATION
# ========================
NODE_ENV=production
PORT=5000
API_URL=https://api.yourdomain.com

# ========================
# DATABASE CONFIGURATION
# ========================
# MongoDB Atlas or local MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/balaji-construction?retryWrites=true&w=majority

# ========================
# CORS CONFIGURATION
# ========================
# Frontend URL - must match exactly for API calls to work
CORS_ORIGIN=https://yourdomain.com

# ========================
# EMAIL CONFIGURATION (Nodemailer)
# ========================
# Gmail: https://myaccount.google.com/apppasswords
# Generate an App Password under Security settings
SMTP_SERVICE=gmail
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM=noreply@balajiconstruction.com

# ========================
# BUSINESS CONFIGURATION
# ========================
WHATSAPP_NUMBER=919637279798
BUSINESS_EMAIL=contact@balajiconstruction.com
BUSINESS_PHONE=+91-XXXXXXXXXX

# ========================
# LOGGING CONFIGURATION
# ========================
LOG_LEVEL=info
LOG_FORMAT=json

# ========================
# RATE LIMITING (Optional)
# ========================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========================
# SECURITY (Optional)
# ========================
JWT_SECRET=your-jwt-secret-key
SESSION_SECRET=your-session-secret-key

# ========================
# DEPLOYMENT MONITORING (Optional)
# ========================
# For services like Sentry, New Relic, etc.
SENTRY_DSN=
ENVIRONMENT_TAG=production
